<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Dark splash screen theme - used before Compose takes over -->
    <style name="Theme.RepAttack" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#FF1C1B1F</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <item name="postSplashScreenTheme">@style/Theme.RepAttack.Compose</item>
    </style>

    <!-- Post-splash theme - minimal, Compose handles the real theming -->
    <style name="Theme.RepAttack.Compose" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowBackground">#FF1C1B1F</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>
</resources>