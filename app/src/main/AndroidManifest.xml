<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.VIBRATE" />

    <application
        android:name="com.repattack.RepAttackApplication"
        android:allowBackup="false"
        android:enableOnBackInvokedCallback="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.RepAttack">

        <activity
            android:name="com.repattack.MainActivity"
            android:exported="true"
            android:theme="@style/Theme.RepAttack">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name="com.repattack.LogSessionActivity"
            android:theme="@style/Theme.RepAttack.Compose"
            android:windowSoftInputMode="adjustNothing" />

        <activity
            android:name="com.repattack.WorkoutDetailActivity"
            android:theme="@style/Theme.RepAttack.Compose" />

        <activity
            android:name="com.repattack.ExerciseCatalogActivity"
            android:theme="@style/Theme.RepAttack.Compose" />

        <activity
            android:name="com.repattack.ExerciseHistoryActivity"
            android:theme="@style/Theme.RepAttack.Compose" />

        <activity
            android:name="com.repattack.ProgramActivity"
            android:theme="@style/Theme.RepAttack.Compose" />

    </application>
</manifest>